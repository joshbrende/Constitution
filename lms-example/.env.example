APP_NAME="TTM Group LMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.ttm-group.co.za

# For local development, set: APP_ENV=local, APP_DEBUG=true, APP_URL=http://localhost/Training_2/lms/public

# TTM Group branding (optional overrides; defaults in config/brand.php)
# BRAND_WEBSITE_URL=https://www.ttm-group.co.za
