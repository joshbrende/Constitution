# Copy this file to `.env` in the repository root (same folder as `docker-compose.yml`).
# Docker Compose reads that `.env` for ${VAR} substitution in docker-compose.yml.
# The file `.env` is gitignored — never commit real production secrets.
#
# Example values suit local development only. Use strong, unique values in production.

DB_PASSWORD=constitution
MYSQL_PASSWORD=constitution
MYSQL_ROOT_PASSWORD=rootpassword
