APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Password reset: link validity (minutes) and min seconds between new reset emails per address.
AUTH_PASSWORD_RESET_EXPIRE_MINUTES=60
AUTH_PASSWORD_RESET_THROTTLE_SECONDS=60

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production: use LOG_LEVEL=info or warning to avoid debug noise; LOG_STACK=daily for rotation (see LOG_DAILY_DAYS).
# Alerts: add Slack Incoming Webhook to log errors (and optional separate ops ping):
# LOG_STACK=daily,slack
# LOG_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# LOG_SLACK_LEVEL=error
# OPS_ALERT_SLACK_WEBHOOK_URL=  (optional; defaults to LOG_SLACK_WEBHOOK_URL for queue-health failures)
# Optional Sentry (after: composer require sentry/sentry-laravel): SENTRY_LARAVEL_DSN=

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional: version badge on Admin → Documentation (defaults to 1.0.0 in config/admin_guide.php)
# APP_DOC_VERSION=1.0.0

# Government ICT integrations (internal-only outbound allowlist)
# Comma-separated hostnames the backend is permitted to call.
# Example: INTEGRATION_ALLOWLIST_HOSTS=idm.gov.local,gateway.gov.local,hr.gov.local
INTEGRATION_ALLOWLIST_HOSTS=
# Default timeout for outbound internal service calls
INTEGRATION_HTTP_TIMEOUT_SECONDS=10

# Zimbabwe Govt portal (internal) — National ID verification (stub)
GOV_ID_PORTAL_BASE_URL=
# If true, membership-granting course enrolment requires verified national ID (once portal is implemented).
GOV_ID_ENFORCE_MEMBERSHIP_VERIFICATION=false
